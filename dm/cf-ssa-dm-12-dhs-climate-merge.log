. *****************************************************************************
> ***
. * GENERATE LATEX SUMMARY TABLES
. *****************************************************************************
> ***
. 
. di as txt ""


. di as txt "==================================================================
> ======"
========================================================================

. di as txt "GENERATING LATEX SUMMARY TABLES"
GENERATING LATEX SUMMARY TABLES

. di as txt "==================================================================
> ======"
========================================================================

. 
. * Create output directory for LaTeX tables if it doesn't exist
. cap mkdir "$cf_overleaf/table"

. 
. *****************************************************************************
> ***
. * TABLE 1: Overall Merge Results
. *****************************************************************************
> ***
. 
. di as txt ""


. di as txt "Creating Table 1: Overall Merge Results..."
Creating Table 1: Overall Merge Results...

. 
. file open merge_table using "$cf_overleaf/table/dhs_climate_merge_results.tex
> ", write replace

. 
. * Write table header
. file write merge_table "\begin{tabular}{lrrrr}" _n

. file write merge_table "\toprule" _n

. file write merge_table "Country & Total Obs & Matched & Unmatched & Merge Rat
> e (\%) \\" _n

. file write merge_table " & (1) & (2) & (3) & (4) \\" _n

. file write merge_table "\midrule" _n

. 
. * Initialize accumulators for totals
. local sum_total = 0

. local sum_matched = 0

. local sum_unmatched = 0

. 
. * Write country rows
. foreach code of local country_codes {
  2.     GetCountryName, code("`code'")
  3.     local country_name "`r(name)'"
  4.     
.     * Only include if processing was successful
.     if "${`code'_status}" == "Success" {
  5.         * Accumulate totals
.         local sum_total = `sum_total' + ${`code'_total_obs}
  6.         local sum_matched = `sum_matched' + ${`code'_matched}
  7.         local sum_unmatched = `sum_unmatched' + ${`code'_unmatched}
  8.         
.         * Write row
.         file write merge_table "`country_name' & ${`code'_total_obs} & ${`cod
> e'_matched} & ${`code'_unmatched} & ${`code'_merge_rate} \\" _n
  9.     }
 10. }

. 
. * Calculate overall merge rate
. if `sum_total' > 0 {
.     local overall_rate: di %5.2f (`sum_matched' / `sum_total') * 100
. }

. else {
.     local overall_rate = 0
. }

. 
. * Write total row
. file write merge_table "\midrule" _n

. file write merge_table "\textbf{Total} & \textbf{`sum_total'} & \textbf{`sum_
> matched'} & \textbf{`sum_unmatched'} & \textbf{`overall_rate'} \\" _n

. file write merge_table "\bottomrule" _n

. file write merge_table "\end{tabular}" _n

. 
. * Add table notes
. file write merge_table "\end{table}" _n

. 
. file close merge_table

. 
. di as txt "  SUCCESS: Table saved to $cf_overleaf/table/dhs_climate_merge_res
> ults.tex"
