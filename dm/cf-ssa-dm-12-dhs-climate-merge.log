. * Program to get DHS folder name from country name
. * Handles the three exceptions: Ivory Coast, Congo Democratic Republic, The G
> ambia
. capture program drop GetDHSFolder

. program define GetDHSFolder, rclass
  1.     syntax, country(string)
  2.     
.     * Default: convert to lowercase and replace spaces with underscores
.     local folder_name = lower(subinstr("`country'", " ", "_", .))
  3.     
.     * Handle exceptions
.     if "`country'" == "Ivory Coast" {
  4.         local folder_name "cote_divoire"
  5.     }
  6.     else if "`country'" == "Congo Democratic Republic" {
  7.         local folder_name "drc"
  8.     }
  9.     else if "`country'" == "The Gambia" {
 10.         local folder_name "gambia"
 11.     }
 12.     
.     return local folder "`folder_name'"
 13. end

. 
. *****************************************************************************
> ***
. * MAIN PROCESSING LOOP
. *****************************************************************************
> ***
. 
. * Define list of country codes
. local country_codes "BEN BFA BDI CMR CAF TCD COM COG DRC ETH GAB GMB GHA GIN 
> IVC KEN LSO LBR MDG MWI MLI MOZ NMB NER NGA RWA SEN SLE ZAF SWZ TZA TGO UGA Z
> MB ZWE"

. *local country_codes "LBR"
. 
. 
. * Initialize tracking locals
. local success_count = 0

. local fail_count = 0

. local low_merge_countries ""

. local failed_countries ""

. local success_countries ""

. 
. * Process each country
. foreach code of local country_codes {
  2.     
.     * Get country name and folder name
.     GetCountryName, code("`code'")
  3.     local country_name "`r(name)'"
  4.     
.     GetDHSFolder, country("`country_name'")
  5.     local folder_name "`r(folder)'"
  6.     
.     di as txt ""
  7.     di as txt "===========================================================
> ============="
  8.     di as txt "Processing: `country_name' (`code')"
  9.     di as txt "===========================================================
> ============="
 10.     
.     * Define file paths
.     local dhs_file "$cf/data/source/dhs/`folder_name'/`folder_name'_dhs_IR.dt
> a"
 11.     local temp_file "$cf/data/derived/dhs/05-dhs-region-cohort-temperature
> /`country_name'-dhs-cohort-temperature.dta"
 12.     local precip_file "$cf/data/derived/dhs/04-dhs-region-cohort-precipita
> tion/`country_name'-dhs-cohort-precipitation.dta"
 13.     local output_file "$cf/data/derived/dhs/06-dhs-survey-climate-merge/`c
> ountry_name'-dhs-ir-climate-merged.dta"
 14.     
.     * Check if source files exist
.     capture confirm file "`dhs_file'"
 15.     local dhs_exists = (_rc == 0)
 16.     
.     capture confirm file "`temp_file'"
 17.     local temp_exists = (_rc == 0)
 18.     
.     capture confirm file "`precip_file'"
 19.     local precip_exists = (_rc == 0)
 20.     
.     * Report file existence
.     di as txt "  DHS file:    `dhs_file'"
 21.     di as txt "               Exists: " cond(`dhs_exists', "Yes", "NO - MI
> SSING")
 22.     di as txt "  Temp file:   `temp_file'"
 23.     di as txt "               Exists: " cond(`temp_exists', "Yes", "NO - M
> ISSING")
 24.     di as txt "  Precip file: `precip_file'"
 25.     di as txt "               Exists: " cond(`precip_exists', "Yes", "NO -
>  MISSING")
 26.     
.     * Skip if any file is missing
.     if !`dhs_exists' | !`temp_exists' | !`precip_exists' {
 27.         di as err "  ERROR: One or more source files missing. Skipping `co
> untry_name'."
 28.         local fail_count = `fail_count' + 1
 29.         local failed_countries "`failed_countries' `country_name'"
 30.         
.         * Store failure status in global for table
.         global `code'_status "Failed"
 31.         global `code'_failure_reason "Missing files"
 32.         
.         continue
 33.     }
 34.     
.     *************************************************************************
> *
.     * STAGE 1: Load and prepare datasets
.     *************************************************************************
> *
.     
.     di as txt ""
 35.     di as txt "  STAGE 1: Loading and preparing datasets"
 36.     di as txt "  ----------------------------------------"
 37.     
.     * Load DHS data
.     use "`dhs_file'", clear
 38.     local dhs_n_initial = _N
 39.     di as txt "    DHS observations loaded: `dhs_n_initial'"
 40.     
.     * ASSERTION: Check caseid uniquely identifies observations
.     capture isid caseid int_year
 41.     if _rc != 0 {
 42.         di as err "    ASSERTION FAILED: caseid and int_year do not unique
> ly identify observations"
 43.         di as err "    Skipping `country_name'"
 44.         local fail_count = `fail_count' + 1
 45.         local failed_countries "`failed_countries' `country_name'"
 46.         
.         * Store failure status in global for table
.         global `code'_status "Failed"
 47.         global `code'_failure_reason "Duplicate IDs"
 48.         
.         continue
 49.     }
 50.     di as txt "    ASSERTION PASSED: caseid uniquely identifies observatio
> ns"
 51.     
.     * Decode region variable to create DHSREGEN
.     decode reg, gen(DHSREGEN)
 52. 
.     * Clean: trim whitespace and convert to proper case
.     if inlist("`country_name'", "Burundi","The Gambia", "Sierra Leone", "Swaz
> iland", "Mozambique") {
 53.         gen DHSREGEN_clean = proper(strtrim(DHSREGEN))
 54.         count if DHSREGEN != DHSREGEN_clean
 55.         if r(N) > 0 {
 56.             di as txt "    NOTE: Cleaned `r(N)' DHSREGEN values (trimmed/p
> roper case)"
 57.         }
 58.         drop DHSREGEN
 59.         rename DHSREGEN_clean DHSREGEN
 60.     }
 61.     levelsof DHSREGEN
 62. 
.     * Clean: Manual fixes for known issues
.     if "`country_name'" == "Sierra Leone" {
 63.         replace DHSREGEN = "Western" if DHSREGEN == "North Western"
 64.     }
 65.     label var DHSREGEN "DHS region identifier"
 66.     
.     
.     * ASSERTION: Check decode was successful (no empty strings)
.     count if DHSREGEN == "" | missing(DHSREGEN)
 67.     local empty_regions = r(N)
 68.     if `empty_regions' > 0 {
 69.         di as err "    WARNING: `empty_regions' observations have missing/
> empty DHSREGEN"
 70.     }
 71.     else {
 72.         di as txt "    ASSERTION PASSED: All observations have valid DHSRE
> GEN values"
 73.     }
 74.     
.     * Rename mom_yob to cohort
.     rename mom_yob cohort
 75. 
.     * ASSERTION: Check no missing values in merge keys
.     count if missing(DHSREGEN) | missing(cohort) | missing(int_year)
 76.     local missing_keys = r(N)
 77.     if `missing_keys' > 0 {
 78.         di as txt "    WARNING: `missing_keys' observations have missing m
> erge key values"
 79.         di as txt "      - These will not merge with weather data"
 80.     }
 81.     else {
 82.         di as txt "    ASSERTION PASSED: No missing values in merge keys"
 83.     }
 84. 
.         capture {
 85.         // Replace the missing code with actual missings for whether respo
> ndent is currently working
.         replace mom_work = . if mom_work == 9
 86. 
.         // Replace the non-numeric responses for ideal number of children wit
> h missings
.         replace mom_ideal =. if inlist(mom_ideal, 94, 95, 96, 99)
 87. 
.         // Replace the missing codes for mom_edyears with missings
.         replace mom_edyears =. if inlist(mom_edyears, 99)
 88. 
.         // Marital status variable has some issues
.         replace marital = "Divorced" if marital == "divorced"
 89.         replace marital = "Married" if marital == "married"
 90.         replace marital = "Living with partner" if marital == "living with
>  partner"
 91.         replace marital = "Never in union" if marital == "never in union"
 92.         replace marital = "Not living together" if inlist(marital, "No lon
> ger living together/separated", "no longer living together/separated", "not l
> iving together")
 93.         replace marital = "Never married" if marital == "never married"
 94.         replace marital = "Widowed" if marital == "widowed"
 95.         replace marital = "Living together" if marital == "living together
> "
 96. 
.         // Replace missing codes for cowives with missings
.         replace cowives =. if inlist(cowives, 98, 99)
 97. 
.         // Replace missing codes for husband education years with missings
.         replace husb_edyears =. if inlist(husb_edyears, 98, 99)
 98. 
.         // Replace missing codes and DKs for husband's desire for children wi
> th missings
.         replace husb_desire =. if inlist(husb_desire, 8, 9)
 99. 
.         // Fix inconsistent coding for religion
.         replace religion = "Celestes" if inlist(religion, ""celestes"", "cele
> stes")
100.         replace religion = "Vodoun" if inlist(religion, "vodoun", "traditi
> onal (vodoun)")
101.         replace religion = "Traditional" if inlist(religion, "taditional",
>  "traditional", "traditional/spiritualist")
102.         replace religion = "Islam" if inlist(religion, "moslem", "Muslim",
>  "musulman")
103.         replace religion = "Islam" if inlist(religion, "muslin", "muslim",
>  "islamic", "islam", "muslim/islam")
104.         replace religion = "Catholic" if inlist(religion, "catholic", "cat
> holique")
105.         replace religion = "Other Christian" if inlist(religion, "other ch
> ristian", "other christians", "other chritians")
106.         replace religion = "Other Protestant" if inlist(religion, "other p
> rotestant", "other protestants")
107.         replace religion = "Protestant" if inlist(religion, "protestant", 
> "protestants", "prostestant")
108.         replace religion = "Protestant" if inlist(religion, "protestant/ o
> ther christian", "protestant/other christian")
109.         replace religion = "None" if inlist(religion, "none",  "no religio
> n", "no religion + other")
110.         replace religion = "Other" if inlist(religion, "other", "other rel
> igions", "Other religion")
111.         replace religion = "Other" if inlist(religion, "salvation army", "
> zephirin/matsouaniste/ngunza")
112.         replace religion = "Other" if inlist(religion, "zephirrin/matsouan
> ist/ngunza", "sect", "jehovah witness") 
113.         replace religion = "Other" if inlist(religion, "nature worship", "
> new religions (eglises rebeillees)") 
114.         replace religion = "Other" if inlist(religion, "eglise de r�veil",
>  "arm�e du salut", "traditional")
115.         replace religion = "Other" if inlist(religion, "other/missing", "r
> oman catholic", "pentecostal/charismatic") 
116.         replace religion = "Other" if inlist(religion, "presbyterian", "pr
> otest /oth cristian")
117.         replace religion = "Other" if inlist(religion, "bundu dia kongo", 
> "vuvamu", "spiritualist")
118.         replace religion = "Other" if inlist(religion, "apostolic sect", "
> pentecostal", "spiritual")
119.         replace religion = "Animist" if inlist(religion, "animist", "animi
> ste", "traditional / animist")
120.         replace religion = "Animist" if inlist(religion, "traditionnal/ani
> mist", "tradition/animist")
121.         replace religion = "Adventist" if inlist(religion, "Adventist", "A
> dventiste", "adventist/jehova", "adventiste/jehova")
122.         replace religion = "Animalist" if religion == "animalist"
123.         replace religion = "Kimbanguism" if inlist(religion, "kibanguist",
>  "kimbanguist", "kimbanguiste")
124.         replace religion = "Orthodox" if religion == "orthodox"
125.         replace religion = "Atheist" if religion == "atheist"
126.         replace religion = "Christianity" if inlist(religion, "Christian",
>  "christianity", "christian")
127.         replace religion = "Anglican" if inlist(religion, "anglican") 
128.         replace religion = "Methodist" if inlist(religion, "methodist")
129.         }
130. 
.     * Create indicator for not having any children
.     gen no_child = .
131.     replace no_child = 1 if total_babies == 0 & !missing(total_babies)
132.     replace no_child = 0 if total_babies >= 0 & !missing(total_babies)
133.     label variable no_child "Respondent does not have children"
134. 
.     * Create indicator for no surviving children
.     gen no_surv_child = .
135.     replace no_surv_child = 1 if no_child == 0 & living_babies == 0 & !mis
> sing(living_babies)
136.     replace no_surv_child = 0 if no_child == 0 & living_babies >= 0 & !mis
> sing(living_babies)
137.     label variable no_surv_child "Respondent does not have surviving child
> ren"
138. 
.     * Create indicator for having had at least one child
.     gen has_child = .
139.     replace has_child = 1 if total_babies >= 1 & !missing(total_babies)
140.     replace has_child = 0 if total_babies == 0 & !missing(total_babies)
141.     label variable has_child "Respondent has at least one child"
142. 
.     * Report merge key value ranges
.     qui sum cohort
143.     di as txt "    Cohort range: `r(min)' - `r(max)'"
144.     qui sum int_year
145.     di as txt "    Survey year range: `r(min)' - `r(max)'"
146.     qui tab DHSREGEN
147.     di as txt "    Number of regions: `r(r)'"
148.     
.     * Save as temp file
.     tempfile dhs_temp
149.     save `dhs_temp', replace
150.     
.     *************************************************************************
> *
.     * STAGE 2: Merge weather datasets
.     *************************************************************************
> *
.     
.     di as txt ""
151.     di as txt "  STAGE 2: Merging weather datasets"
152.     di as txt "  ----------------------------------"
153.     
.     * Load temperature data
.     use "`temp_file'", clear
154.     local temp_n = _N
155.     di as txt "    Temperature observations: `temp_n'"
156.     
.     * ASSERTION: Check temperature data is uniquely identified
.     capture isid DHSREGEN cohort int_year
157.     if _rc != 0 {
158.         di as err "    WARNING: Temperature data not uniquely identified b
> y DHSREGEN cohort int_year"
159.         * Try to make it unique by keeping first observation
.         bysort DHSREGEN cohort int_year: keep if _n == 1
160.         di as txt "    Kept first observation per group. New N = `=_N'"
161.     }
162.     else {
163.         di as txt "    ASSERTION PASSED: Temperature data uniquely identif
> ied"
164.     }
165.     
.     * Save temp temperature file
.     tempfile temp_weather
166.     save `temp_weather', replace
167.     
.     * Load precipitation data
.     use "`precip_file'", clear
168.     local precip_n = _N
169.     di as txt "    Precipitation observations: `precip_n'"
170.     
.     * ASSERTION: Check precipitation data is uniquely identified
.     capture isid DHSREGEN cohort int_year
171.     if _rc != 0 {
172.         di as err "    WARNING: Precipitation data not uniquely identified
>  by DHSREGEN cohort int_year"
173.         bysort DHSREGEN cohort int_year: keep if _n == 1
174.         di as txt "    Kept first observation per group. New N = `=_N'"
175.     }
176.     else {
177.         di as txt "    ASSERTION PASSED: Precipitation data uniquely ident
> ified"
178.     }
179.     
.     * Merge temperature with precipitation
.     merge 1:1 DHSREGEN cohort int_year using `temp_weather'
180.     
.     * Check merge results for weather data
.     tab _merge
181.     
.     * Count merge outcomes
.     count if _merge == 1
182.     local precip_only = r(N)
183. 
.     ta int_year if _merge == 1
184.     ta cohort if _merge == 1
185.     levelsof DHSREGEN if _merge == 1
186. 
. 
.     count if _merge == 2
187.     local temp_only = r(N)
188. 
.     count if _merge == 3
189.     local both_weather = r(N)
190.     
.     di as txt ""
191.     di as txt "    Weather merge results:"
192.     di as txt "      Precipitation only (_merge=1): `precip_only'"
193.     di as txt "      Temperature only (_merge=2):   `temp_only'"
194.     di as txt "      Both matched (_merge=3):       `both_weather'"
195.     
.     * ASSERTION: Perfect merge for weather data
.     local total_weather = `precip_only' + `temp_only' + `both_weather'
196.     local weather_merge_rate = (`both_weather' / `total_weather') * 100
197.     
.     if `precip_only' > 0 | `temp_only' > 0 {
198.         di as err "    ASSERTION FAILED: Temperature-Precipitation merge i
> s not perfect"
199.         di as err "    Weather merge rate: " %5.2f `weather_merge_rate' "%
> "
200.         di as err "    Continuing with matched observations only..."
201.         keep if _merge == 3
202.     }
203.     else {
204.         di as txt "    ASSERTION PASSED: Perfect merge between temperature
>  and precipitation"
205.     }
206.     
.     drop _merge
207.     
.     * Save combined weather data
.     tempfile weather_combined
208.     save `weather_combined', replace
209.     local weather_n = _N
210.     di as txt "    Combined weather observations: `weather_n'"
211.     
.     *************************************************************************
> *
.     * STAGE 2b: Merge DHS with weather data
.     *************************************************************************
> *
.     
.     di as txt ""
212.     di as txt "  STAGE 2b: Merging DHS with weather data"
213.     di as txt "  ----------------------------------------"
214.     
.     * Load DHS data
.     use `dhs_temp', clear
215.     
.     * Merge with weather data
.     merge m:1 DHSREGEN cohort int_year using `weather_combined'
216.     
.     * Detailed merge diagnostics
.     tab _merge
217.     
.     count if _merge == 1
218.     local dhs_only = r(N)
219.     count if _merge == 2
220.     local weather_only = r(N)
221.     count if _merge == 3
222.     local matched = r(N)
223.     
.     local total_dhs = `dhs_only' + `matched'
224.     local merge_rate = (`matched' / `total_dhs') * 100
225.     
.     di as txt ""
226.     di as txt "    DHS-Weather merge results:"
227.     di as txt "      DHS only (unmatched, _merge=1):     `dhs_only'"
228.     di as txt "      Weather only (_merge=2):            `weather_only'"
229.     di as txt "      Matched (_merge=3):                 `matched'"
230.     di as txt "      -----------------------------------------"
231.     di as txt "      Total DHS observations:             `total_dhs'"
232.     di as txt "      Merge rate:                         " %5.2f `merge_ra
> te' "%"
233.     
.     * Store merge statistics in globals for LaTeX table
.     global `code'_status "Success"
234.     global `code'_total_obs "`total_dhs'"
235.     global `code'_matched "`matched'"
236.     global `code'_unmatched "`dhs_only'"
237.     global `code'_merge_rate: di %5.2f `merge_rate'
238.     global `code'_weather_only "`weather_only'"
239.     
.     * Count unique regions
.     qui tab DHSREGEN if _merge == 3
240.     global `code'_regions_matched "`r(r)'"
241.     qui tab DHSREGEN if _merge == 1
242.     global `code'_regions_unmatched "`r(r)'"
243.     
.     * Check for weather-only observations (shouldn't happen in normal case)
.     if `weather_only' > 0 {
244.         di as txt ""
245.         di as txt "    NOTE: `weather_only' weather observations have no m
> atching DHS records"
246.         di as txt "    These may represent region-cohort combinations not 
> in the survey"
247.     }
248.     
.     * Flag low merge rate countries (< 90%)
.     if `merge_rate' < 90 {
249.         di as err ""
250.         di as err "    *** WARNING: LOW MERGE RATE (<90%) ***"
251.         di as err "    `country_name' has only " %5.2f `merge_rate' "% of 
> observations merged"
252.         local low_merge_countries "`low_merge_countries' `country_name'(`=
> round(`merge_rate',0.1)'%)"
253.         global `code'_low_merge "Yes"
254.     }
255.     else {
256.         global `code'_low_merge "No"
257.     }
258.     
.     * Analyze unmatched DHS observations
.     if `dhs_only' > 0 {
259.         di as txt ""
260.         di as txt "    Analysis of unmatched DHS observations:"
261.         
.         preserve
262.         keep if _merge == 1
263.         
.         * By region
.         di as txt "      By region:"
264.         tab DHSREGEN, sort
265.         
.         * By cohort range
.         qui sum cohort
266.         di as txt "      Cohort range of unmatched: `r(min)' - `r(max)'"
267.         
.         * By survey year
.         di as txt "      By survey year:"
268.         tab int_year
269.         
.         restore
270.     }
271.     
.     * Keep all DHS observations (matched and unmatched)
.     keep if _merge == 1 | _merge == 3
272. 
.     di as text "    Regions with unmatched DHS observations: "
273.     levelsof DHSREGEN if _merge == 1
274. 
.         levelsof cohort if _merge == 1
275. 
.         levelsof int_year if _merge == 1
276.     
.     
.     * Create indicator for successful merge
.     gen byte climate_data_merged = (_merge == 3)
277.     label var climate_data_merged "Successfully merged with climate data (
> 1=yes)"
278.     
.     drop _merge
279.     
.     *************************************************************************
> *
.     * STAGE 3: Final checks and save
.     *************************************************************************
> *
.     
.     di as txt ""
280.     di as txt "  STAGE 3: Final checks and save"
281.     di as txt "  -------------------------------"
282.     
.     * ASSERTION: Final dataset still uniquely identified by caseid
.     capture isid caseid int_year
283.     if _rc != 0 {
284.         di as err "    ASSERTION FAILED: Final dataset not uniquely identi
> fied by caseid"
285.         di as err "    Checking for duplicates..."
286.         duplicates report caseid
287.         di as err "    Skipping save for `country_name'"
288.         local fail_count = `fail_count' + 1
289.         local failed_countries "`failed_countries' `country_name'"
290.         
.         * Update failure status
.         global `code'_status "Failed"
291.         global `code'_failure_reason "Duplicate final IDs"
292.         
.         continue
293.     }
294.     di as txt "    ASSERTION PASSED: Final dataset uniquely identified by 
> caseid"
295.     
.     * Report final counts
.     local final_n = _N
296.     count if climate_data_merged == 1
297.     local merged_n = r(N)
298.     count if climate_data_merged == 0
299.     local unmerged_n = r(N)
300.     
.     di as txt ""
301.     di as txt "    Final dataset summary:"
302.     di as txt "      Initial DHS observations:     `dhs_n_initial'"
303.     di as txt "      Final observations:           `final_n'"
304.     di as txt "      With climate data:            `merged_n'"
305.     di as txt "      Without climate data:         `unmerged_n'"
306.     
.     * ASSERTION: No observations lost
.     if `final_n' != `dhs_n_initial' {
307.         di as err "    WARNING: Observation count changed from `dhs_n_init
> ial' to `final_n'"
308.     }
309.     else {
310.         di as txt "    ASSERTION PASSED: All DHS observations retained"
311.     }
312.     
.     * Add metadata
.     label data "DHS-Climate merged data for `country_name' - Created `c(curre
> nt_date)'"
313.     notes: Created by dhs_climate_merge.do on `c(current_date)' `c(current
> _time)'
314.     notes: Source DHS file: `dhs_file'
315.     notes: Source temperature file: `temp_file'
316.     notes: Source precipitation file: `precip_file'
317.     notes: Merge rate: `=round(`merge_rate', 0.01)'%
318.     
.     * Save final dataset
.     save "`output_file'", replace
319.     di as txt ""
320.     di as txt "    SAVED: `output_file'"
321.     
.     * Update success counter
.     local success_count = `success_count' + 1
322.     local success_countries "`success_countries' `country_name'"
323.     
.     * Clear temporary files from memory
.     clear
324. }

