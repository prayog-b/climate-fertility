. *****************************************************************************
> ***
. * Degree Days Calculator
. *****************************************************************************
> ***
. 
. capture program drop calculate_degree_days

. program define calculate_degree_days
  1.     syntax, lowerbound(real) upperbound(real) intervals(real)
  2.     
.     di "  Calculating degree days for thresholds `lowerbound'(`intervals')`up
> perbound'"
  3.     
.     * Validate required temperature variables exist
.     foreach var in temp_max temp_mean {
  4.         capture confirm numeric variable `var'
  5.         if _rc {
  6.             di as error "    ERROR: Required variable `var' not found or n
> ot numeric"
  7.             exit 111
  8.         }
  9.     }
 10.     
.     * Calculate degree days for each threshold (scaled by 100)
.     * Note: unscaled = scaled * 100, so compute on the fly if needed
.     * Uses capture to skip thresholds that already exist (allows multiple cal
> ls)
.     forvalues threshold = `lowerbound'(`intervals')`upperbound' {
 11.         foreach stat in max mean {
 12.             capture confirm variable temp_`stat'_dd_`threshold'
 13.             if _rc {
 14.                 qui gen temp_`stat'_dd_`threshold' = max(temp_`stat' - `th
> reshold', 0) / 100
 15.                 label variable temp_`stat'_dd_`threshold' "Degree days abo
> ve `threshold'C (`stat' temp), scaled by 100"
 16.             }
 17.         }
 18.     }
 19.     
.     * Clean up original temperature variables
.     di "  Degree days calculation completed"
 20. end

. 
. *****************************************************************************
> ***
. * Age Range Exposure Generator
. *****************************************************************************
> ***
. 
. capture program drop generate_age_range_exposure

. program define generate_age_range_exposure
  1.     
.     di "  Generating age-specific temperature exposure variables"
  2.     
.     * Validate required variables
.     foreach var in cohort year {
  3.         capture confirm numeric variable `var'
  4.         if _rc {
  5.             di as error "    ERROR: Required variable `var' not found or n
> ot numeric"
  6.             exit 111
  7.         }
  8.     }
  9.     
.     * Calculate age and create age group indicators
.     * ── Fine bins: six 5-year bins (configurable) ──
.     local bin_starts "15 20 25 30 35 40"
 10.     local bin_ends   "19 24 29 34 39 44"
 11.     local bin_labels "15_19 20_24 25_29 30_34 35_39 40_44"
 12.     local n_bins : word count `bin_starts'
 13. 
.     * ── Broad bins: two halves of the reproductive span ──
.     local broad_starts "15 30"
 14.     local broad_ends   "29 44"
 15.     local broad_labels "15_29 30_44"
 16.     local n_broad : word count `broad_starts'
 17. 
.     cap drop age
 18.     qui gen age = year - cohort
 19. 
.     * Create fine-bin indicators
.     forvalues i = 1/`n_bins' {
 20.         local s : word `i' of `bin_starts'
 21.         local e : word `i' of `bin_ends'
 22.         local lbl : word `i' of `bin_labels'
 23.         qui gen age_`lbl' = inrange(age, `s', `e')
 24.         label variable age_`lbl' "Ages `s'-`e' indicator"
 25.     }
 26. 
.     * Create broad-bin indicators
.     forvalues i = 1/`n_broad' {
 27.         local s : word `i' of `broad_starts'
 28.         local e : word `i' of `broad_ends'
 29.         local lbl : word `i' of `broad_labels'
 30.         qui gen age_`lbl' = inrange(age, `s', `e')
 31.         label variable age_`lbl' "Ages `s'-`e' indicator"
 32.     }
 33. 
.     label variable age "Age in year"
 34. 
.     * Create age-specific variants for all degree day variables
.     qui ds temp_*_dd_*
 35.     local dd_vars "`r(varlist)'"
 36. 
.     foreach var of local dd_vars {
 37.         * Fine bins
.         forvalues i = 1/`n_bins' {
 38.             local s : word `i' of `bin_starts'
 39.             local e : word `i' of `bin_ends'
 40.             local lbl : word `i' of `bin_labels'
 41.             qui gen `var'_age_`lbl' = `var' * age_`lbl'
 42.             label variable `var'_age_`lbl' "`var' exposure ages `s'-`e'"
 43.         }
 44.         * Broad bins
.         forvalues i = 1/`n_broad' {
 45.             local s : word `i' of `broad_starts'
 46.             local e : word `i' of `broad_ends'
 47.             local lbl : word `i' of `broad_labels'
 48.             qui gen `var'_age_`lbl' = `var' * age_`lbl'
 49.             label variable `var'_age_`lbl' "`var' exposure ages `s'-`e'"
 50.         }
 51.     }
 52.     
.     di "  Age-specific exposure variables created"
 53. end

. 
. *****************************************************************************
> ***
. * Temperature Data Processing
. *****************************************************************************
> ***
. capture program drop TemperatureDataProcessor

. program define TemperatureDataProcessor
  1.     syntax, method(string) country_code(string) [dhs_years(string) max_coh
> ort(string)]
  2. 
.     * Get country name from code
.     GetCountryName, code("`country_code'")
  3.     local country_name "`r(name)'"
  4. 
.     if "`country_name'" == "" {
  5.         di as error "ERROR: Unknown country code `country_code'"
  6.         exit 198
  7.     }
  8. 
.     if "`method'" == "load_and_aggregate" {
  9.         di "    Loading and aggregating temperature data for `country_name
> ' (`country_code')"
 10.         * Check if the country ERA data file exists
.         local data_file "$cf/data/derived/dhs/02-dhs-region-daily-data/`count
> ry_name'-era-dhs-region-day-1940-2023.dta"
 11.         di "     Looking for data file: `data_file'"
 12. 
.         capture confirm file "`data_file'"
 13.         if _rc {
 14.             di as error "    ERROR: Data file for `country_name' not found
> ."
 15.             exit 601
 16.         }
 17. 
.         use "`data_file'", clear
 18.         
.         qui count
 19.         di "    Loaded `r(N)' observations"
 20.         
.         if r(N) == 0 {
 21.             di as error "    ERROR: ERA data file is empty"
 22.             exit 459
 23.         }
 24.         
.         * Check required variables
.         local required_vars "DHSREGEN DHS_code temp_max temp_mean day month y
> ear"
 25.         foreach var of local required_vars {
 26.             capture confirm variable `var'
 27.             if _rc {
 28.                 di as error "    ERROR: Required variable `var' not found 
> in data"
 29.                 exit 111
 30.             }
 31.         }
 32. 
.         di "   Keeping variables we need"
 33.         keep DHSREGEN DHS_code temp_max temp_mean day month year
 34.         drop if missing(temp_max) | missing(temp_mean)
 35. 
.         di "   Preparing to merge with crop phenology data"
 36.         decode DHSREGEN, gen(dhsreg_decoded)
 37.         destring dhsreg_decoded, replace
 38.         drop DHSREGEN
 39.         rename dhsreg_decoded DHSREGEN
 40. 
.         preserve
 41.             local phenology_file "$cf/data/derived/dhs/03-dhs-fao-growing-
> season/dhs-crop-phenology-summary-stats.csv"
 42.             di "    Looking for phenology file: `phenology_file'"
 43.             
.             capture confirm file "`phenology_file'"
 44.             if _rc {
 45.                 di as error "    ERROR: Phenology file not found: `phenolo
> gy_file'"
 46.                 exit 601
 47.             }
 48. 
.             import delimited using "`phenology_file'", clear
 49.             qui count
 50.             di "    Loaded `r(N)' observations from phenology data"
 51. 
.             di "   Looking for phenology data for: `country_name'"
 52.             ren (cntrynamee dhsregen dhs_code) (COUNTRY DHSREGEN DHS_code)
 53.             
.             keep if COUNTRY == "`country_name'"
 54. 
.             qui count
 55.             if r(N) == 0 {
 56.                 di as error "    ERROR: No phenology data found for `count
> ry_name'"
 57.                 di          "    Creating empty phenology dataset"
 58.                 clear 
 59.                 gen DHS_code = .
 60.                 forvalues m = 1/12 {
 61.                     gen growing_month_`m' = 0
 62.                 }
 63.             }
 64.             else {
 65.                 di as text "    Found phenology data for `country_name' wi
> th `r(N)' observations"
 66.                 keep DHSREGEN DHS_code growing_month_*
 67.             }
 68. 
.             tempfile crop_phenology
 69.             save "`crop_phenology'"
 70.         restore
 71. 
.         di "   Merging ERA and phenology data ..."
 72.         merge m:1 DHS_code using `crop_phenology'
 73.         di " Examining merge success ..."
 74.         tab _merge
 75.         drop _merge 
 76. 
.         di "   Creating growing and non-growing season indicators ..."
 77.         gen byte gs = 0 
 78.         gen byte ngs = 0 
 79.         forvalues m = 1/12 {
 80.             capture confirm variable growing_month_`m'
 81.             if !_rc {
 82.                 replace gs = 1 if growing_month_`m' == 1 & month == `m'
 83.                 replace ngs = 1 if growing_month_`m' == 0 & month == `m'
 84.             }
 85.         }    
 86. 
.         * Ensure DHS_code is numeric 
.         capture confirm string variable DHS_code
 87.         if !_rc {
 88.             destring DHS_code, replace force
 89.         }
 90. 
. 
.         ** Create temperature bins 
.         foreach var in temp_max {
 91.             * First bin: < 18
.             gen `var'_less_18 = (`var' < 18)
 92.             
.             * 3-degree bins: 18-21, 21-24, 24-27, 27-30, 30-33
.             forvalues lower = 18(3)30 {
 93.                 local upper = `lower' + 3
 94.                 gen `var'_`lower'_`upper' = (`var' >= `lower' & `var' < `u
> pper')
 95.             }
 96.             
.             * Last bin: >= 33
.             gen `var'_more_33 = (`var' >= 33)
 97.         }
 98. 
.         egen temp_max_sum = rowtotal(temp_max_less_18 temp_max_18_21 temp_max
> _21_24 ///
>                               temp_max_24_27 temp_max_27_30 temp_max_30_33 te
> mp_max_more_33)
 99. 
.         * Should equal 1 for all non-missing temp_max
.         assert temp_max_sum == 1 if !missing(temp_max)
100.         
.         * Check for any missing temperatures
.         count if missing(temp_max)
101.         if r(N) > 0 {
102.             di as error "Warning: `r(N)' observations have missing temp_ma
> x"
103.         }
104. 
.         drop temp_max_sum
105. 
.         di "    Calculating degree days ..."
106.         calculate_degree_days, lowerbound(24) upperbound(38) intervals(2)
107.         calculate_degree_days, lowerbound(26) upperbound(30) intervals(1)
108. 
.         di "    Creating growing/non-growing season variants ..."
109.         qui ds temp_*_dd_*
110.         local dd_vars "`r(varlist)'"
111. 
.         foreach var of local dd_vars {
112.             qui gen `var'_gs = `var' * gs
113.             qui gen `var'_ngs = `var' * ngs
114. 
.             label variable `var'_gs "`var'  growing season"
115.             label variable `var'_ngs "`var'  non-growing season"
116.         }
117. 
.         di "      Collapsing to annual level ..."
118.         ds temp_*_dd_* temp_max_less_18 temp_max_18_21 temp_max_21_24 temp
> _max_24_27 temp_max_27_30 temp_max_30_33 temp_max_more_33
119.         local all_temp_vars "`r(varlist)'"
120. 
.         collapse (sum) `all_temp_vars' (mean) temp_mean (max) temp_max, by(DH
> S_code DHSREGEN year)
121.         recast float year 
122. 
.         egen days_per_year = rowtotal(temp_max_less_18 temp_max_18_21 temp_ma
> x_21_24 ///
>                               temp_max_24_27 temp_max_27_30 temp_max_30_33 te
> mp_max_more_33)
123. 
.         * Summary statistics
.         sum days_per_year
124.         tab days_per_year
125. 
.         * Check for years with < 365 days
.         count if days_per_year < 365
126.         list year days_per_year if days_per_year < 365
127. 
. 
.         qui count 
128.         di "   Annual data has `r(N)' observations"
129. 
.         * Create directory if it doesn't exist
.         capture mkdir "$cf/data/derived/dhs/05-dhs-region-cohort-temperature/
> 01-annual-data"
130.         local save_file "$cf/data/derived/dhs/05-dhs-region-cohort-tempera
> ture/01-annual-data/`country_name'-temperature_annual.dta"
131. 
.         di "    Saving to: `save_file' ..."
132.         save "`save_file'", replace 
133.         di "Annual temperature data saved successfully."
134.     }       
135. end 

. 
. *****************************************************************************
> ***
. * Cohort Metrics Calculator (Temperature)
. *****************************************************************************
> ***
. 
. capture program drop CohortMetricsCalculator

. program define CohortMetricsCalculator
  1.     syntax, country_code(string) [reproductive_span(real 30) dhs_year(real
>  2020) save_file(string)]
  2. 
.     di "     Calculating cohort metrics for DHS year: `dhs_year' with reprodu
> ctive span `reproductive_span' years"
  3. 
.     * Get country name from code 
.     GetCountryName, code("`country_code'")
  4.     local country_name "`r(name)'"
  5. 
.     if "`country_name'" == "" {
  6.         di as error "ERROR: Unknown country code `country_code'"
  7.         exit 198
  8.     }
  9. 
.     * Check current dataset
.     qui count
 10.     di "    Starting with `r(N)' observations"
 11.     di "    Generating age variables"
 12. 
.     generate_age_range_exposure
 13. 
.     di "    Collapsing to cohort level ..."
 14. 
.     * Get all temperature variables
.     qui ds temp_*_dd_* temp_max_less_18 temp_max_18_21 temp_max_21_24 temp_ma
> x_24_27 temp_max_27_30 temp_max_30_33 temp_max_more_33
 15.     local temp_vars "`r(varlist)'"
 16. 
.     if "`temp_vars'" == "" {
 17.         di as error "    ERROR: No temperature variables found for cohort 
> aggregation"
 18.         exit 459
 19.     }
 20. 
.     collapse (sum) `temp_vars' (mean) temp_mean (max) temp_max, by(DHS_code D
> HSREGEN cohort)
 21. 
.     * After second collapse to cohort level
.     egen total_days = rowtotal(temp_max_less_18 temp_max_18_21 temp_max_21_24
>  temp_max_24_27 temp_max_27_30 temp_max_30_33 temp_max_more_33)
 22.     di "Summary of total days"
 23.     sum total_days if cohort <= 1976
 24. 
.     * Diagnostic checks at cohort level:
.     scatter total_days cohort
 25.     gen years_coverage = total_days / 365.25
 26.     sum years_coverage
 27.     sum cohort if years_coverage < 30
 28.     local min_cohort = r(min)
 29.     list cohort total_days years_coverage if cohort == `min_cohort'
 30. 
.     gen int_year = `dhs_year'
 31. 
.     local save_file "$cf/data/derived/dhs/05-dhs-region-cohort-temperature/02
> -dhs-year-metrics/`country_code'-dhs-metrics-`dhs_year'.dta"
 32. 
.     local output_path "`save_file'"
 33.     di "    Saving cohort metrics to: `output_path' ..."
 34. 
.     save "`output_path'", replace
 35.     qui count
 36.     di "Cohort metrics saved successfully with `r(N)' observations."
 37. end 

. 
. *****************************************************************************
> ***
. * Census Selection
. *****************************************************************************
> ***
. 
. capture program drop CensusSelector

. program define CensusSelector
  1.     syntax, country_code(string) [log_file(string)]
  2. 
.     gen age_in_dhs_year = int_year - cohort 
  3. 
.     bys DHS_code cohort: egen max_age_observed = max(age_in_dhs_year)
  4.     gen cohort_reaches_reproductive = (max_age_observed >= 15)
  5. 
.     gen exposure_years = max(0, min(age_in_dhs_year, 44) - 15 + 1)
  6.     replace exposure_years = 0 if age_in_dhs_year < 15
  7. 
.     gen full_exposure = (exposure_years >= 30)
  8. 
.     drop max_age_observed
  9. 
. end 

. 
. 
. *****************************************************************************
> ***
. * Main Temperature Workflow
. *****************************************************************************
> ***
. capture program drop TemperatureAnalysisWorkflow

. program define TemperatureAnalysisWorkflow
  1.     syntax, method(string) country_code(string) [dhs_years(string) max_coh
> ort(string) reproductive_span(real 30) cleanup(string) temp_files(string) tar
> get_age(real 45)]
  2. 
.     * Get country name from code 
.     GetCountryName, code("`country_code'")
  3.     local country_name "`r(name)'"
  4. 
.     if "`country_name'" == "" {
  5.         di as error "ERROR: Unknown country code `country_code'"
  6.         exit 198
  7.     }
  8. 
.     if "`method'" == "run_full_analysis" {
  9.         di ""
 10.         di "==== Starting temperature analysis for `country_name' (`countr
> y_code') ===="
 11. 
.         ClimateAnalysisConfig, method(init)
 12. 
.         * Check for DHS country to years mapping file
.         preserve 
 13.             local mapping_file "$cf/data/derived/dhs/00-dhs-country-survey
> year-mappings/surveycd_reg_year.dta"
 14.             di "   Checking DHS mapping file: `mapping_file' ..."
 15. 
.             capture confirm file "`mapping_file'"
 16.             if _rc {
 17.                 di as error "   ERROR: DHS country to years mapping file n
> ot found."
 18.                 restore 
 19.                 exit 601
 20.             }
 21. 
.             use "`mapping_file'", clear
 22.             qui count
 23.             di "   Loaded `r(N)' observations from DHS mapping file"
 24.             * Some countries have different names in the mapping file vs. 
> the ERA5 data files
.             local mapping_cname "`country_name'"
 25.             if "`country_name'" == "Ivory Coast" local mapping_cname "Cote
>  d'Ivoire"
 26.             di "   Keeping only the records for `mapping_cname' ..."
 27.             keep if COUNTRY == "`mapping_cname'"
 28.             di "Filtered to `country_name'"
 29. 
.             qui count 
 30.             if r(N) == 0 {
 31.                 di as error "   ERROR: No DHS survey years found for `coun
> try_name' in mapping file."
 32.                 restore 
 33.                 exit 459
 34.             }
 35.             ren year int_year 
 36.             levelsof int_year , local(dhs_years) 
 37.             local n_dhsyears = wordcount("`dhs_years'")
 38.             di "   Found `n_dhsyears' DHS survey years for `country_name'"
 39.         restore 
 40. 
.         * Step 1: Load and aggregate temperature data
.         capture noisily TemperatureDataProcessor, method("load_and_aggregate"
> ) country_code("`country_code'")
 41.         if _rc {
 42.             di as error "   ERROR: Temperature data processing failed for 
> `country_name'"
 43.             exit _rc
 44.         }
 45. 
.         * Step 2: Process cohort metrics by DHS year 
.         di "   Processing cohort metrics by DHS year ..."
 46.         local temp_files ""
 47.         local dhs_num = 0 
 48.         foreach dhs_year in `dhs_years' { 
 49.             local ++dhs_num
 50.             di   "   DHS year `dhs_num'/`n_dhsyears': `dhs_year' ..."
 51. 
.             * Check cohort file
.             local cohort_file "$cf/data/derived/dhs/00-dhs-country-surveyyear
> -mappings/dhs-cohort-year.dta"
 52.             capture confirm file "`cohort_file'"
 53.             if _rc {
 54.                 di as error "   ERROR: Cohort year file not found: `cohort
> _file'"
 55.                 continue
 56.             }
 57. 
.             use "`cohort_file'", clear
 58.             keep if year <= `dhs_year'
 59.             keep if cohort <= `dhs_year' - 15
 60. 
.             su cohort
 61.             list if cohort == 2005 & year == 2020
 62. 
.             qui count 
 63.             di "      Cohort-year combinations: `r(N)'"
 64.             
.             if r(N) == 0 {
 65.                 di "      WARNING: No valid cohort-year combinations for D
> HS `dhs_year'"
 66.                 continue
 67.             }
 68.             
.             local temp_file "$cf/data/derived/dhs/05-dhs-region-cohort-temper
> ature/01-annual-data/`country_name'-temperature_annual.dta"
 69. 
.             capture confirm file "`temp_file'"
 70.             if _rc {
 71.                 di as error "   ERROR: Temperature file not found: `temp_f
> ile'"
 72.                 continue
 73.             }
 74. 
.             di "    Joining with temperature data ..."
 75.             capture noisily joinby year using "`temp_file'"
 76.             if _rc {
 77.                 di as error "   ERROR: Failed to join temperature data"
 78.                 continue 
 79.             }
 80.             local temp_file_name "`country_code'-dhs-metrics-`dhs_year'"
 81. 
.             count if cohort == 2005
 82. 
.             capture noisily CohortMetricsCalculator, ///
>                 country_code("`country_code'") ///
>                 dhs_year(`dhs_year') ///
>                 reproductive_span(`reproductive_span') ///
>                 save_file("`temp_file_name'")
 83. 
.             if _rc == 0 { 
 84.                 local temp_files "`temp_files' `temp_file_name'"
 85.             }
 86.             else {
 87.                 di "   WARNING: Failed to calculate metrics for DHS `dhs_y
> ear' "
 88.             }
 89.         }
 90. 
.         if "`temp_files'" == "" {
 91.             di as error "   ERROR: No temperature metric files were create
> d for `country_name'"
 92.             exit 459
 93.         }
 94. 
.         * Step 3: Combine DHS year files 
.         di "   Combining DHS years ..."
 95.         TemperatureAnalysisWorkflow, ///
>             method("combine_and_select_dhs") ///
>             country_code("`country_code'") ///
>             temp_files("`temp_files'") ///
>             target_age(`target_age')
 96. 
.         if "`cleanup'" == "true" {
 97.             di "  Cleaning up temporary files..."
 98.             TemperatureAnalysisWorkflow, method("cleanup_temp_files") ///
>                 country_code("`country_code'") ///
>                 temp_files("`temp_files'")
 99.         }
100. 
.         di "=== Analysis complete for `country_name' (`country_code') ==="
101.     }
102. 
.     else if "`method'" == "combine_and_select_dhs" { 
103.         di "   Combining DHS datasets ..."
104.         local first_file: word 1 of `temp_files'
105. 
.         capture confirm file "$cf/data/derived/dhs/05-dhs-region-cohort-tempe
> rature/02-dhs-year-metrics/`first_file'.dta"
106.         if _rc {
107.             di as error "   ERROR: First DHS metrics file not found: `firs
> t_file'"
108.             exit 601
109.         }
110. 
.         use "$cf/data/derived/dhs/05-dhs-region-cohort-temperature/02-dhs-yea
> r-metrics/`first_file'.dta", clear
111.         qui count 
112.         local first_obs = r(N)
113.         di "    Loaded first file: `first_obs' observations"
114. 
.         local remaining_files: list temp_files - first_file
115.         local remaining_count = wordcount("`remaining_files'")
116. 
.         if `remaining_count' > 0 {
117.             di "   Appending `remaining_count' remaining files ..."
118.             foreach file in `remaining_files' { 
119.                 capture append using "$cf/data/derived/dhs/05-dhs-region-c
> ohort-temperature/02-dhs-year-metrics/`file'.dta"
120.                 if _rc {
121.                     di as error "   ERROR: Failed to append file: `file'"
122.                 }
123.             }
124.             qui count 
125.             di "    Combined total: `r(N)' observations"
126.         }
127. 
.         local before_cleaning = r(N)
128.         drop if missing(cohort) | missing(int_year) | missing(DHS_code)
129.         qui count 
130.         local after_cleaning = r(N)
131.         local dropped = `before_cleaning' - `after_cleaning'
132.         if `dropped' > 0 {
133.             di "    Dropped `dropped' observations with missing key variab
> les"
134.         }
135.         di " Clean observations: `after_cleaning' observations"
136. 
.         sort DHS_code cohort int_year
137.         di "   Applying DHS year selection criteria ..."
138.         CensusSelector, country_code("`country_code'")
139. 
.         qui count 
140.         local final_obs = r(N)
141. 
.                 if `final_obs' == 0 {
142.             di as error "    ERROR: No observations after DHS year selecti
> on"
143.             exit 459
144.         }
145.         
.         qui tab int_year
146.         local n_dhsyear_final = r(r)
147.         qui levelsof int_year, local(final_dhsyear_list)
148.         di "      Final dataset: `final_obs' observations across `n_dhsyea
> r_final' DHS years"
149.         di "      DHS years: `final_dhsyear_list'"
150. 
.         ** Label all of the degree day variables
.         * Define age bins (must match generate_age_range_exposure)
.         local bin_starts "15 20 25 30 35 40"
151.         local bin_ends   "19 24 29 34 39 44"
152.         local bin_labels "15_19 20_24 25_29 30_34 35_39 40_44"
153.         local n_bins : word count `bin_starts'
154. 
.         local broad_starts "15 30"
155.         local broad_ends   "29 44"
156.         local broad_labels "15_29 30_44"
157.         local n_broad : word count `broad_starts'
158. 
.         foreach measure in max mean {
159.         foreach thres in 24 26 27 28 29 30 32 34 36 38 {
160.             label variable temp_`measure'_dd_`thres' "Degree days (`measur
> e' temp) `thres'C, scaled by 100"
161. 
.             foreach season in gs ngs {
162.                 label variable temp_`measure'_dd_`thres'_`season' "Degree 
> days (`measure' temp) `thres'C (`season'), scaled by 100"
163.             }
164. 
.             * Fine bins
.             forvalues i = 1/`n_bins' {
165.                 local s : word `i' of `bin_starts'
166.                 local e : word `i' of `bin_ends'
167.                 local lbl : word `i' of `bin_labels'
168.                 label variable temp_`measure'_dd_`thres'_age_`lbl' "Degree
>  days (`measure' temp) `thres'C ages `s'-`e', scaled by 100"
169.                 foreach season in gs ngs {
170.                     label variable temp_`measure'_dd_`thres'_`season'_age_
> `lbl' "Degree days (`measure' temp) `thres'C ages `s'-`e', (`season'), scaled
>  by 100"
171.                 }
172.             }
173. 
.             * Broad bins
.             forvalues i = 1/`n_broad' {
174.                 local s : word `i' of `broad_starts'
175.                 local e : word `i' of `broad_ends'
176.                 local lbl : word `i' of `broad_labels'
177.                 label variable temp_`measure'_dd_`thres'_age_`lbl' "Degree
>  days (`measure' temp) `thres'C ages `s'-`e', scaled by 100"
178.                 foreach season in gs ngs {
179.                     label variable temp_`measure'_dd_`thres'_`season'_age_
> `lbl' "Degree days (`measure' temp) `thres'C ages `s'-`e', (`season'), scaled
>  by 100"
180.                 }
181.             }
182.         }
183.         }
184. 
.         label variable temp_mean "Mean temperature, Celsius"
185.         label variable temp_max "Maximum temperature, Celsius"
186. 
.         label variable temp_max_less_18 "Max Temperature bin, less than 18C"
187.         label variable temp_max_18_21 "Max Temperature bin, 18 - 21C"
188.         label variable temp_max_21_24 "Max Temperature bin, 21 - 24C"
189.         label variable temp_max_24_27 "Max Temperature bin, 24 - 27C"
190.         label variable temp_max_27_30 "Max Temperature bin, 27 - 30C"
191.         label variable temp_max_30_33 "Max Temperature bin, 30 - 33C"
192.         label variable temp_max_more_33 "Max Temperature bin, more than 33
> C"
193. 
.         label variable int_year "DHS survey year"
194.         label variable age_in_dhs_year "Age in DHS survey year"
195.         label variable cohort_reaches_reproductive "Cohort reaches reprodu
> ctive age"
196.         label variable exposure_years "Years of exposure"
197.         label variable full_exposure "Full exposure"
198. 
.         label variable cohort "Cohort"
199.         label variable DHS_code "DHS code"
200.         label variable DHSREGEN "DHS region"
201. 
.         
.         local final_file "$cf/data/derived/dhs/05-dhs-region-cohort-temperatu
> re/`country_name'-dhs-cohort-temperature.dta"
202.         capture save "`final_file'", replace 
203.         if _rc != 0 {
204.             di as error "   ERROR: Cannot save final dataset to `final_fil
> e'"
205.             di as error "   Check directory permissions and disk space."
206.             exit 603 
207.         }
208.         di "   Saved final dataset: `country_name'-dhs-cohort-temperature.
> dta"
209.     }
210. 
.     else if "`method'" == "cleanup_temp_files" {
211.         local files_deleted = 0 
212.         di "    Deleting temporary cohort metric files ..."
213. 
.         foreach file in `temp_files' {
214.             local file_path "$cf/data/derived/dhs/05-dhs-region-cohort-tem
> perature/02-dhs-year-metrics/`file'.dta"
215.             capture erase "`file_path'"
216.             if _rc == 0 {
217.                 local ++files_deleted
218.             }
219.         }
220. 
.         // di "    Deleting intermediate temperature file ..."
.         // local temp_file "$cf/data/derived/dhs/05-dhs-region-cohort-tempera
> ture/01-annual-data/`country_name'-temperature_annual.dta"
.         // capture erase "`temp_file'"
.         // if _rc == 0 {
.         //     local ++files_deleted 
.         // }
. 
.         di "   Cleanup complete: `files_deleted' temporary files removed"
221.     }
222. end

