.     capture program drop load_and_process_era 

.     program define load_and_process_era 
  1.         syntax, country_code(string)
  2.         /*
>         Program: load_and_process_era
>         Description: Loads and validates ERA precipitation data for a specifi
> c country
>         Parameters: 
>             country_code: Three-letter country code (e.g. "BEN", "BWA")
>         Output:
>             Loads ERA daily precipitation data for the specified country into
>  memory
>         */
. 
.         * Get country name from code
.         GetCountryName, code("`country_code'")
  3.         local country_name "`r(name)'"
  4.         
.         di "  Loading ERA data for `country_name' (`country_code')..."
  5.         * Check if the country ERA data file exists
.         local data_file "$cf/data/derived/dhs/02-dhs-region-daily-data/`count
> ry_name'-era-dhs-region-day-1940-2023.dta"
  6.         di "     Looking for data file: `data_file'"
  7. 
.         capture confirm file "`data_file'"
  8.         if _rc {
  9.             di as error "    ERROR: Data file for `country_name' not found
> ."
 10.             exit 601
 11.         }
 12. 
.         use "`data_file'", clear
 13.         qui count
 14.         di "    Loaded `r(N)' observations"
 15.         
.         if r(N) == 0 {
 16.             di as error "    ERROR: ERA data file is empty"
 17.             exit 459
 18.         }
 19.         
.         * Check required variables
.         local required_vars "DHSREGEN DHS_code precip day month year"
 20.         foreach var of local required_vars {
 21.             capture confirm variable `var'
 22.             if _rc {
 23.                 di as error "    ERROR: Required variable `var' not found 
> in data"
 24.                 exit 111
 25.             }
 26.         }
 27. 
.         di "   Keeping variables we need"
 28.         keep DHSREGEN DHS_code precip day month year
 29.         drop if missing(precip)
 30. 
.         di "   Preparing to merge with crop phenology data"
 31.         decode DHSREGEN, gen(dhsreg_decoded)
 32.         destring dhsreg_decoded, replace
 33.         drop DHSREGEN
 34.         rename dhsreg_decoded DHSREGEN
 35.         di "ERA data loaded successfully. Proceeding to merge crop phenolo
> gy data"
 36. 
.         preserve
 37.             local phenology_file "$cf/data/derived/dhs/03-dhs-fao-growing-
> season/dhs-crop-phenology-summary-stats.csv"
 38.             di "    Looking for phenology file: `phenology_file'"
 39.             
.             capture confirm file "`phenology_file'"
 40.             if _rc {
 41.                 di as error "    ERROR: Phenology file not found: `phenolo
> gy_file'"
 42.                 exit 601
 43.             }
 44. 
.             import delimited using "`phenology_file'", clear
 45.             qui count
 46.             di "    Loaded `r(N)' observations from phenology data"
 47. 
.             di "   Looking for phenology data for: `country_name'"
 48.             ren (cntrynamee dhsregen dhs_code) (COUNTRY DHSREGEN DHS_code)
 49.             
.             keep if COUNTRY == "`country_name'"
 50.             ren gs1_has_data gs1_valid
 51.             ren gs2_has_data gs2_valid
 52.             gen no_valid_pixels = (gs1_valid == 0 & gs2_valid == 0)
 53.             label var no_valid_pixels "Indicator for no valid phenology pi
> xels"
 54.             
. 
.             qui count
 55.             if r(N) == 0 {
 56.                 di as error "    ERROR: No phenology data found for `count
> ry_name'"
 57.                 di          "    Creating empty phenology dataset"
 58.                 clear 
 59.                 gen DHS_code = .
 60.                 forvalues m = 1/12 {
 61.                     gen growing_month_`m' = 0
 62.                 }
 63.             }
 64.             else {
 65.                 di as text "    Found phenology data for `country_name' wi
> th `r(N)' observations"
 66.                 keep DHSREGEN DHS_code no_valid_pixels growing_month_*
 67.             }
 68. 
.             tempfile crop_phenology
 69.             save "`crop_phenology'"
 70.         restore
 71. 
.         di "   Merging ERA and phenology data ..."
 72.         merge m:1 DHS_code using `crop_phenology'
 73.         di " Examining merge success ..."
 74.         tab _merge
 75. 
.         * Explicit merge quality summary (easy to grep in log)
.         qui count if _merge == 1
 76.         local n_era_only = r(N)
 77.         qui count if _merge == 2
 78.         local n_pheno_only = r(N)
 79.         qui count if _merge == 3
 80.         local n_matched = r(N)
 81.         if `n_era_only' == 0 & `n_pheno_only' == 0 {
 82.             di "  ✓ MERGE PERFECT: all `n_matched' obs matched (no ERA-onl
> y or phenology-only rows)"
 83.         }
 84.         else {
 85.             if `n_era_only' > 0  di "  ✗ MERGE NOTE: `n_era_only' ERA obs 
> have NO phenology match — growing months will default to non-growing season"
 86.             if `n_pheno_only' > 0 di "  ✗ MERGE NOTE: `n_pheno_only' pheno
> logy rows have NO ERA match (dropped)"
 87.         }
 88. 
.         * ----------------------------------------------------------------
.         * FIX: For ERA5 DHS_codes with no phenology match (_merge == 1),
.         * growing_month_m is missing (.) rather than 0.  In Stata,
.         * (. == 0) evaluates to FALSE, so those observations would get
.         * gs = 0 AND ngs = 0, making precip_gs = precip_ngs = 0 while
.         * precip retains its full value — breaking the decomposition
.         * identity precip = precip_gs + precip_ngs.
.         * Treat unmatched regions as entirely non-growing season (ngs = 1)
.         * so the identity holds.  The no_valid_pixels flag documents them.
.         * ----------------------------------------------------------------
.         forvalues m = 1/12 {
 89.             capture confirm variable growing_month_`m'
 90.             if !_rc {
 91.                 qui count if missing(growing_month_`m')
 92.                 if r(N) > 0 {
 93.                     di "    NOTE: `r(N)' obs have missing growing_month_`m
> ' (no phenology match) — set to 0 (non-growing season)"
 94.                     replace growing_month_`m' = 0 if missing(growing_month
> _`m')
 95.                 }
 96.             }
 97.         }
 98.         drop _merge
 99. 
.         di "   Creating growing and non-growing season indicators ..."
100.         gen byte gs = 0
101.         gen byte ngs = 0
102.         forvalues m = 1/12 {
103.             capture confirm variable growing_month_`m'
104.             if !_rc {
105.                 replace gs = 1 if growing_month_`m' == 1 & month == `m'
106.                 replace ngs = 1 if growing_month_`m' == 0 & month == `m'
107.             }
108.         }
109. 
.         * Create seasonal precipitation variables
.         gen precip_gs = precip * gs
110.         gen precip_ngs = precip * ngs
111. 
.         * ASSERTION: precip = precip_gs + precip_ngs for every daily observat
> ion.
.         * By construction gs + ngs = 1 for all rows (growing_month_m is binar
> y
.         * and missing values were zeroed out above), so this should always pa
> ss.
.         * A failure here means some observations have gs = ngs = 0, i.e. a mo
> nth
.         * was not covered by the growing_month loop — signalling a merge or d
> ata
.         * problem that would silently corrupt the seasonal decomposition.
.         tempvar _check_decomp
112.         gen double `_check_decomp' = precip_gs + precip_ngs
113.         qui count if abs(`_check_decomp' - precip) > 1e-6 & !missing(preci
> p)
114.         if r(N) > 0 {
115.             di as error "    ASSERTION FAILED: precip ≠ precip_gs + precip
> _ngs for `r(N)' observations"
116.             di as error "    This means gs + ngs ≠ 1 for some rows — check
>  the growing_month merge"
117.             exit 459
118.         }
119.         di "    ✓ Decomposition identity holds: precip = precip_gs + preci
> p_ngs (all `c(N)' obs)"
120.         drop `_check_decomp'
121. 
.         * Label variables
.         la var precip_gs "Growing season precipitation"
122.         la var precip_ngs "Non-growing season precipitation"
123. 
.         * Validate seasonal variables
.         qui sum precip_gs
124.         di "    Growing season precip - Mean: `r(mean)', SD: `r(sd)'"
125.         qui sum precip_ngs
126.         di "    Non-growing season precip - Mean: `r(mean)', SD: `r(sd)'"
127.         
.         di "  Seasonal variables created successfully"
128. 
.         * Ensure DHS_code is numeric 
.         capture confirm string variable DHS_code
129.         if !_rc {
130.             destring DHS_code, replace force
131.         }
132. 
.         di "Aggregating data to annual level ..."
133.         collapse (sum) precip precip_gs precip_ngs (first) no_valid_pixels
> , by(DHS_code DHSREGEN year)
134.         recast float year 
135.                 * Validate annual data
.         qui count
136.         di "    Annual data has `r(N)' observations"
137.         
.         qui count if missing(precip)
138.         if r(N) > 0 {
139.             di "    WARNING: Annual data has `r(N)' missing values for pre
> cip"
140.         }
141.         
.         qui count if missing(precip_gs)
142.         if r(N) > 0 {
143.             di "    WARNING: Annual data has `r(N)' missing values for pre
> cip_gs"
144.         }
145.         
.         qui count if missing(precip_ngs)
146.         if r(N) > 0 {
147.             di "    WARNING: Annual data has `r(N)' missing values for pre
> cip_ngs"
148.         }
149. 
.         * Create directory if it doesn't exist
.         capture mkdir "$cf/data/derived/dhs/04-dhs-region-cohort-precipitatio
> n/01-annual-data"
150.         
.         * Save annual data
.         local save_file "$cf/data/derived/dhs/04-dhs-region-cohort-precipitat
> ion/01-annual-data/`country_name'_precip_annual.dta"
151.         di "    Saving annual data to: `save_file'"
152.         save "`save_file'", replace
153.         
.         di "  Annual aggregation completed successfully"
154.     end

. 
. 
.     capture program drop create_gammafit_dataset

.     program define create_gammafit_dataset
  1.         syntax, country_code(string)
  2.         /*
>             Program: create_gammafit_dataset
>             Description: Creates dataset with gamma distribution fits for pre
> cipitation variables
>             Parameters:
>                 country_code: Three-letter country code
>             Output:
>                 Saves dataset with gamma distribution parameters and SPI valu
> es
>         */
.         di as text "   Creating gamma fit dataset with scaling ..."
  3. 
.         * Get country name
.         GetCountryName, code("`country_code'")
  4.         local country_name "`r(name)'"
  5.         
.         local annual_file "$cf/data/derived/dhs/04-dhs-region-cohort-precipit
> ation/01-annual-data/`country_name'_precip_annual.dta"
  6.         capture confirm file "`annual_file'"
  7.         if _rc {
  8.             di as error "    ERROR: Annual precipitation file not found: `
> annual_file'"
  9.             exit 601
 10.         }
 11. 
.         use "`annual_file'", clear
 12.             
.         qui count
 13.         di "    Loaded `r(N)' annual observations for gamma fitting"
 14.         
.         sort DHS_code year
 15.         
.         * Fit gamma distributions 
.         GammaDistributionFitter, variables("precip precip_gs precip_ngs")
 16. 
.         * Keep only essential variables for gamma fit results 
.         keep DHSREGEN DHS_code year no_valid_pixels abn_precip* precip*_spi a
> lpha beta P spi i_gammafit_scaled
 17. 
.         * Save gamma fit results 
.         local save_file "$cf/data/derived/dhs/04-dhs-region-cohort-precipitat
> ion/02-gammafit-data/`country_code'_gammafit.dta"
 18.         di "   Saving gamma fit results to : `save_file'"
 19.         save "`save_file'", replace
 20.         di " Gamma fit dataset created successfully"
 21.     end

. 
.     ** Cohort Metrics Calculator
.     capture program drop cohort_metrics_calculator

.     program define cohort_metrics_calculator
  1.         syntax, country_code(string) [reproductive_span(real 30) dhs_year(
> real 2020) save_file(string)]
  2.         /*
>         Program: cohort_metrics_calculator
>         Description: Calculates cohort-level precipitation metrics including 
> scaling indicators
>         Parameters:
>             country_code: Three-letter country code
>             reproductive_span: Number of years representing reproductive span
>             dhs_year: Census year to consider
>             save_file: File path to save cohort-level precipitation data
>         */
.         
.         di "    Calculating cohort metrics for dhs `dhs_year'"
  3.         
.         * Get country name from code
.         GetCountryName, code("`country_code'")
  4.         local country_name "`r(name)'"
  5.         
.         * Check current dataset
.         qui count
  6.         di "      Starting with `r(N)' observations"
  7.         di "      Generating age variables ..."
  8.         * ── Fine bins: six 5-year bins (configurable) ──
.         local bin_starts "15 20 25 30 35 40"
  9.         local bin_ends   "19 24 29 34 39 44"
 10.         local bin_labels "15_19 20_24 25_29 30_34 35_39 40_44"
 11.         local n_bins : word count `bin_starts'
 12. 
.         * ── Broad bins: two halves of the reproductive span ──
.         local broad_starts "15 30"
 13.         local broad_ends   "29 44"
 14.         local broad_labels "15_29 30_44"
 15.         local n_broad : word count `broad_starts'
 16. 
.         * Create fine-bin indicators
.         forvalues i = 1/`n_bins' {
 17.             local s : word `i' of `bin_starts'
 18.             local e : word `i' of `bin_ends'
 19.             local lbl : word `i' of `bin_labels'
 20.             qui gen age_`lbl' = inrange(age, `s', `e')
 21.         }
 22.         * Create broad-bin indicators
.         forvalues i = 1/`n_broad' {
 23.             local s : word `i' of `broad_starts'
 24.             local e : word `i' of `broad_ends'
 25.             local lbl : word `i' of `broad_labels'
 26.             qui gen age_`lbl' = inrange(age, `s', `e')
 27.         }
 28. 
.         local gammafit_file "$cf/data/derived/dhs/04-dhs-region-cohort-precip
> itation/02-gammafit-data/`country_code'_gammafit.dta"
 29. 
.         capture confirm file "`gammafit_file'"
 30.         if _rc {
 31.             di "      WARNING: Gamma fit file not found: `gammafit_file'"
 32.             di "      Proceeding without SPI variables"
 33.         }
 34.         else {
 35.             di "      Merging with gamma fit results (including scaling in
> dicators)"
 36.             qui merge m:1 DHS_code year using "`gammafit_file'"
 37.             drop _merge
 38. 
.             * Report on scaling usage
.             qui sum i_gammafit_scaled
 39.             if r(N) > 0 & r(mean) > 0 {
 40.                 di "      Scaling was used for `=round(r(mean)*100, 0.1)'%
>  of observations"
 41.             }
 42.         }
 43. 
.         * Base variables including the new scaling indicator
.         local base_vars "precip abn_precip_dry abn_precip_wet abn_precip prec
> ip_spi precip_gs_spi precip_ngs_spi precip_gs precip_ngs abn_precip_gs abn_pr
> ecip_ngs abn_precip_gs_dry abn_precip_ngs_dry abn_precip_gs_wet abn_precip_ng
> s_wet i_gammafit_scaled"
 44. 
.         local vars_created = 0
 45.         foreach var of local base_vars {
 46.             capture confirm variable `var'
 47.             if _rc == 0 {
 48.                 * Don't create age-specific versions for the scaling indic
> ator
.                 if "`var'" != "i_gammafit_scaled" {
 49.                     forvalues i = 1/`n_bins' {
 50.                         local lbl : word `i' of `bin_labels'
 51.                         qui gen `var'_`lbl' = `var' * age_`lbl'
 52.                     }
 53.                     forvalues i = 1/`n_broad' {
 54.                         local lbl : word `i' of `broad_labels'
 55.                         qui gen `var'_`lbl' = `var' * age_`lbl'
 56.                     }
 57.                 }
 58.                 local ++vars_created
 59.             }
 60.         }
 61. 
.         di "      Collapsing to cohort level..."
 62. 
.         * Build age-bin-specific collapse specs dynamically
.         local coll_sum_bins ""
 63.         local coll_mean_bins ""
 64.         * Fine bins
.         forvalues i = 1/`n_bins' {
 65.             local lbl : word `i' of `bin_labels'
 66.             local coll_sum_bins "`coll_sum_bins' precip_total_`lbl' = prec
> ip_`lbl' precip_gs_total_`lbl' = precip_gs_`lbl' precip_ngs_total_`lbl' = pre
> cip_ngs_`lbl'"
 67.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_`lbl' = ab
> n_precip_`lbl' tot_abn_precip_dry_`lbl' = abn_precip_dry_`lbl' tot_abn_precip
> _wet_`lbl' = abn_precip_wet_`lbl'"
 68.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_gs_`lbl' =
>  abn_precip_gs_`lbl' tot_abn_precip_ngs_`lbl' = abn_precip_ngs_`lbl'"
 69.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_gs_dry_`lb
> l' = abn_precip_gs_dry_`lbl' tot_abn_precip_gs_wet_`lbl' = abn_precip_gs_wet_
> `lbl'"
 70.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_ngs_dry_`l
> bl' = abn_precip_ngs_dry_`lbl' tot_abn_precip_ngs_wet_`lbl' = abn_precip_ngs_
> wet_`lbl'"
 71.             local coll_mean_bins "`coll_mean_bins' avg_precip_spi_`lbl' = 
> precip_spi_`lbl' avg_precip_gs_spi_`lbl' = precip_gs_spi_`lbl' avg_precip_ngs
> _spi_`lbl' = precip_ngs_spi_`lbl'"
 72.         }
 73.         * Broad bins
.         forvalues i = 1/`n_broad' {
 74.             local lbl : word `i' of `broad_labels'
 75.             local coll_sum_bins "`coll_sum_bins' precip_total_`lbl' = prec
> ip_`lbl' precip_gs_total_`lbl' = precip_gs_`lbl' precip_ngs_total_`lbl' = pre
> cip_ngs_`lbl'"
 76.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_`lbl' = ab
> n_precip_`lbl' tot_abn_precip_dry_`lbl' = abn_precip_dry_`lbl' tot_abn_precip
> _wet_`lbl' = abn_precip_wet_`lbl'"
 77.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_gs_`lbl' =
>  abn_precip_gs_`lbl' tot_abn_precip_ngs_`lbl' = abn_precip_ngs_`lbl'"
 78.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_gs_dry_`lb
> l' = abn_precip_gs_dry_`lbl' tot_abn_precip_gs_wet_`lbl' = abn_precip_gs_wet_
> `lbl'"
 79.             local coll_sum_bins "`coll_sum_bins' tot_abn_precip_ngs_dry_`l
> bl' = abn_precip_ngs_dry_`lbl' tot_abn_precip_ngs_wet_`lbl' = abn_precip_ngs_
> wet_`lbl'"
 80.             local coll_mean_bins "`coll_mean_bins' avg_precip_spi_`lbl' = 
> precip_spi_`lbl' avg_precip_gs_spi_`lbl' = precip_gs_spi_`lbl' avg_precip_ngs
> _spi_`lbl' = precip_ngs_spi_`lbl'"
 81.         }
 82. 
.         qui collapse ///
>         (first) no_valid_pixels = no_valid_pixels ///
>         (sum) precip_total = precip ///
>             precip_gs_total = precip_gs ///
>             precip_ngs_total = precip_ngs ///
>             tot_abn_precip = abn_precip ///
>             tot_abn_precip_gs = abn_precip_gs ///
>             tot_abn_precip_ngs = abn_precip_ngs ///
>             tot_abn_precip_dry = abn_precip_dry ///
>             tot_abn_precip_wet = abn_precip_wet ///
>             tot_abn_precip_gs_dry = abn_precip_gs_dry ///
>             tot_abn_precip_gs_wet = abn_precip_gs_wet ///
>             tot_abn_precip_ngs_dry = abn_precip_ngs_dry ///
>             tot_abn_precip_ngs_wet = abn_precip_ngs_wet ///
>             `coll_sum_bins' ///
>             tot_gammafit_scaled = i_gammafit_scaled ///
>         (mean) avg_precip_spi = precip_spi ///
>             avg_precip_gs_spi = precip_gs_spi ///
>             avg_precip_ngs_spi = precip_ngs_spi ///
>             `coll_mean_bins' ///
>         , by(DHS_code DHSREGEN cohort)
 83. 
.         qui gen int_year = `dhs_year'
 84. 
.         * Calculate shares (assuming reproductive_span is defined)
.         di "Calculating shares..."
 85. 
.         quietly {
 86.         * Overall shares (denominator = full reproductive span)
.         gen share_abn_precip = tot_abn_precip / `reproductive_span'
 87.         gen share_abn_precip_dry = tot_abn_precip_dry / `reproductive_span
> '
 88.         gen share_abn_precip_wet = tot_abn_precip_wet / `reproductive_span
> '
 89. 
.         * Growing season overall shares
.         gen share_abn_precip_gs = tot_abn_precip_gs / `reproductive_span'
 90.         gen share_abn_precip_gs_dry = tot_abn_precip_gs_dry / `reproductiv
> e_span'
 91.         gen share_abn_precip_gs_wet = tot_abn_precip_gs_wet / `reproductiv
> e_span'
 92. 
.         * Non-growing season overall shares
.         gen share_abn_precip_ngs = tot_abn_precip_ngs / `reproductive_span'
 93.         gen share_abn_precip_ngs_dry = tot_abn_precip_ngs_dry / `reproduct
> ive_span'
 94.         gen share_abn_precip_ngs_wet = tot_abn_precip_ngs_wet / `reproduct
> ive_span'
 95. 
.         * Age-bin-specific shares (denominator = number of years in each bin)
.         * Fine bins
.         forvalues i = 1/`n_bins' {
 96.             local s : word `i' of `bin_starts'
 97.             local e : word `i' of `bin_ends'
 98.             local lbl : word `i' of `bin_labels'
 99.             local bin_years = `e' - `s' + 1
100. 
.             gen share_abn_precip_`lbl'         = tot_abn_precip_`lbl'        
>  / `bin_years'
101.             gen share_abn_precip_dry_`lbl'     = tot_abn_precip_dry_`lbl' 
>     / `bin_years'
102.             gen share_abn_precip_wet_`lbl'     = tot_abn_precip_wet_`lbl' 
>     / `bin_years'
103. 
.             gen share_abn_precip_gs_`lbl'      = tot_abn_precip_gs_`lbl'     
>  / `bin_years'
104.             gen share_abn_precip_gs_dry_`lbl'  = tot_abn_precip_gs_dry_`lb
> l'  / `bin_years'
105.             gen share_abn_precip_gs_wet_`lbl'  = tot_abn_precip_gs_wet_`lb
> l'  / `bin_years'
106. 
.             gen share_abn_precip_ngs_`lbl'     = tot_abn_precip_ngs_`lbl'    
>  / `bin_years'
107.             gen share_abn_precip_ngs_dry_`lbl' = tot_abn_precip_ngs_dry_`l
> bl' / `bin_years'
108.             gen share_abn_precip_ngs_wet_`lbl' = tot_abn_precip_ngs_wet_`l
> bl' / `bin_years'
109.         }
110.         * Broad bins
.         forvalues i = 1/`n_broad' {
111.             local s : word `i' of `broad_starts'
112.             local e : word `i' of `broad_ends'
113.             local lbl : word `i' of `broad_labels'
114.             local bin_years = `e' - `s' + 1
115. 
.             gen share_abn_precip_`lbl'         = tot_abn_precip_`lbl'        
>  / `bin_years'
116.             gen share_abn_precip_dry_`lbl'     = tot_abn_precip_dry_`lbl' 
>     / `bin_years'
117.             gen share_abn_precip_wet_`lbl'     = tot_abn_precip_wet_`lbl' 
>     / `bin_years'
118. 
.             gen share_abn_precip_gs_`lbl'      = tot_abn_precip_gs_`lbl'     
>  / `bin_years'
119.             gen share_abn_precip_gs_dry_`lbl'  = tot_abn_precip_gs_dry_`lb
> l'  / `bin_years'
120.             gen share_abn_precip_gs_wet_`lbl'  = tot_abn_precip_gs_wet_`lb
> l'  / `bin_years'
121. 
.             gen share_abn_precip_ngs_`lbl'     = tot_abn_precip_ngs_`lbl'    
>  / `bin_years'
122.             gen share_abn_precip_ngs_dry_`lbl' = tot_abn_precip_ngs_dry_`l
> bl' / `bin_years'
123.             gen share_abn_precip_ngs_wet_`lbl' = tot_abn_precip_ngs_wet_`l
> bl' / `bin_years'
124.         }
125.         }
126. 
. 
.         * ASSERTION 2: tot_abn_precip should not exceed 30 for any cohort
.         di "      Validating tot_abn_precip bounds..."
127.         qui sum tot_abn_precip
128.         if r(max) > 30 {
129.             di as error "      ASSERTION FAILED: tot_abn_precip exceeds 30
>  (max found: `r(max)')"
130.             di as error "      This violates the reproductive span assumpt
> ion of 30 years"
131.             exit 459
132.         }
133.         di "      ✓ tot_abn_precip validation passed (max: `r(max)')"
134. 
.         * ASSERTION 3: share_abn_precip should not exceed 1 for any cohort
.         di "      Validating share_abn_precip bounds..."
135.         qui sum share_abn_precip
136.         if r(max) > 1 {
137.             di as error "      ASSERTION FAILED: share_abn_precip exceeds 
> 1 (max found: `r(max)')"
138.             di as error "      Share should be a proportion between 0 and 
> 1"
139.             exit 459
140.         }
141.         di "      ✓ share_abn_precip validation passed (max: `r(max)')"
142. 
.         local save_file "$cf/data/derived/dhs/04-dhs-region-cohort-precipitat
> ion/03-cohort-metrics/`country_code'_metrics_`dhs_year'.dta"
143.         
.         local output_path "`save_file'"
144.         //di "      Saving cohort metrics to: `output_path'"
.         qui save "`output_path'", replace
145.         
.         qui count
146.         di "    Cohort metrics saved (`r(N)' observations)"
147.     end

