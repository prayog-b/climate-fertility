. * EXECUTION
. ******************************
.     capture program drop RunPrecipitationAnalysis

.     program define RunPrecipitationAnalysis
  1.         syntax, country_codes(string) [cleanup(string) test_mode(string)]
  2.         
.         /*
>         Program: RunPrecipitationAnalysis
>         Description: Main execution function that runs the complete precipita
> tion analysis pipeline
>         Parameters:
>             country_codes: Space-separated list of country codes to process
>             cleanup: "true" to remove temporary files after processing (optio
> nal)
>             test_mode: "true" to run in test mode with limited countries (opt
> ional)
>         */
.         
.         di ""
  3.         di "==============================================="
  4.         di "PRECIPITATION ANALYSIS PIPELINE EXECUTION"
  5.         di "==============================================="
  6.         di "Start time: $S_TIME, $S_DATE"
  7.         di ""
  8.         
.         * Initialize configuration
.         //ClimateAnalysisConfig, method("init")
.         
.         * Process countries
.         local total_countries : word count `country_codes'
  9.         di "Processing `total_countries' countries"
 10.         di "Countries: `country_codes'"
 11.         di ""
 12.         
.         local country_num = 0
 13.         local countries_completed ""
 14.         local countries_failed ""
 15.         
.         foreach country_code in `country_codes' {
 16.             local ++country_num
 17.             
.             * Get country name for display
.             GetCountryName, code("`country_code'")
 18.             local country_name "`r(name)'"
 19.             
.             di "=============================================================
> ==============="
 20.             di "COUNTRY `country_num'/`total_countries': `country_name' (`
> country_code')"
 21.             di "==========================================================
> =================="
 22.             
.             * Run the full analysis pipeline
.             capture noisily {
 23.                 PrecipitationAnalysisWorkflow, ///
>                     method("run_full_analysis") ///
>                     country_code("`country_code'") ///
>                     cleanup("`cleanup'")
 24.             }
 25.             
.             if _rc == 0 {
 26.                 local countries_completed "`countries_completed' `country_
> code'"
 27.                 di "✓ SUCCESS: `country_name' (`country_code') completed"
 28.             }
 29.             else {
 30.                 local countries_failed "`countries_failed' `country_code'"
 31.                 di "✗ FAILED: `country_name' (`country_code') - Error code
> : `_rc'"
 32.                 
.                 * Provide specific error messages
.                 if _rc == 601 {
 33.                     di "  > File not found error - check data paths"
 34.                 }
 35.                 else if _rc == 459 {
 36.                     di "  > No observations/data error"
 37.                 }
 38.                 else if _rc == 111 {
 39.                     di "  > Variable not found error"
 40.                 }
 41.                 else if _rc == 198 {
 42.                     di "  > Invalid syntax or country code"
 43.                 }
 44.                 else {
 45.                     di "  > Unknown error - check log for details"
 46.                 }
 47.             }
 48.             di ""
 49.         }
 50.         
.         * Generate summary report
.         local completed_count : word count `countries_completed'
 51.         local failed_count : word count `countries_failed'
 52.         
.         di "==============================================="
 53.         di "PIPELINE EXECUTION COMPLETE"
 54.         di "==============================================="
 55.         di "Completion time: $S_TIME, $S_DATE"
 56.         di ""
 57.         di "SUMMARY:"
 58.         di "  Successful: `completed_count'/`total_countries' countries"
 59.         di "  Failed:     `failed_count'/`total_countries' countries"
 60.         di ""
 61.         
.         if `completed_count' > 0 {
 62.             di "SUCCESSFULLY COMPLETED COUNTRIES:"
 63.             foreach country_code in `countries_completed' {
 64.                 GetCountryName, code("`country_code'")
 65.                 di "  ✓ `r(name)' (`country_code')"
 66.             }
 67.             di ""
 68.             
.             * Generate Gamma Scaling Summary Table
.             di "Generating gamma scaling summary table..."
 69.             capture noisily GenerateGammaScalingTable
 70.             if _rc == 0 {
 71.                 di "✓ Gamma scaling table saved to: $cf_overleaf/table/dhs
> _gamma_scaling_summary.tex"
 72.             }
 73.             else {
 74.                 di "WARNING: Could not generate gamma scaling table"
 75.             }
 76.             
.         }
 77. 
.         * Report on gamma fitting failures
.             capture confirm file "$cf/data/derived/dhs/04-dhs-region-cohort-p
> recipitation/02-gammafit-data/gamma_fitting_failures.dta"
 78.             if _rc == 0 {
 79.                 preserve
 80.                     use "$cf/data/derived/dhs/04-dhs-region-cohort-precipi
> tation/02-gammafit-data/gamma_fitting_failures.dta", clear
 81.                     qui count
 82.                     di "  Total DHS units with fitting failures: `r(N)'"
 83.                     di "  Failure log saved to: $cf/data/derived/dhs/04-dh
> s-region-cohort-precipitation/02-gammafit-data/gamma_fitting_failures.dta"
 84.                 restore
 85.             }
 86.             else {
 87.                 di "  No gamma fitting failures across all countries"
 88.             }
 89.         
.         if `failed_count' > 0 {
 90.             di "FAILED COUNTRIES:"
 91.             foreach country_code in `countries_failed' {
 92.                 GetCountryName, code("`country_code'")
 93.                 di "  ✗ `r(name)' (`country_code')"
 94.             }
 95.             di ""
 96.             
.             di "TROUBLESHOOTING TIPS:"
 97.             di "1. Check that all required data files exist:"
 98.             di "   - ERA data: $cf/data/derived/dhs/02-dhs-region-daily-da
> ta/`country_name'-era-dhs-region-day-1940-2023.dta"
 99.             di  "   - Phenology: $cf/data/derived/fao/crop-phenology/crop-
> phenology-summary-stats.csv"
100.             di "   - DHS: $cf/data/derived/ipums/country-dhs-years-mapping
> .dta"
101.             di "   - Cohort: $cf/data/derived/dhs/00-dhs-country-surveyyea
> r-mappings/dhs-cohort-year.dta"
102.             di "2. Verify country names match exactly in phenology and DHS
>  files"
103.             di "3. Check that directories exist and have write permissions
> "
104.             di "4. Run individual countries to identify specific issues"
105.         }
106.         
.         di ""
107.         di "OUTPUTS GENERATED:"
108.         di "  - Country-level precipitation datasets: $cf/data/derived/dhs
> /04-dhs-region-cohort-precipitation/"
109.         di "  - Gamma scaling statistics: $cf/data/derived/dhs/04-dhs-regi
> on-cohort-precipitation/02-gammafit-data/gamma_scaling_statistics.dta"
110.         di "  - Gamma scaling LaTeX table: $cf_overleaf/table/dhs_gamma_sc
> aling_summary.tex"
111.         di ""
112.         di "==============================================="
113.     end

. 
